# LLM (OpenAI-compatible API)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your-token-here
LLM_MODEL=gpt-4o-mini

# Application
APP_HOST=0.0.0.0
APP_PORT=8080

# Oracle Client (required for Oracle Database 11.2 and earlier)
# ORACLE_CLIENT_LIB_DIR: folder with oci.dll (often ...\client_1\bin)
# ORACLE_HOME: client home (parent of bin)
ORACLE_USE_THICK_MODE=true
ORACLE_CLIENT_LIB_DIR=C:\Oracle\client19_64\bin
ORACLE_HOME=C:\Oracle\client19_64
# ORA_TZFILE is optional. If set, the .dat file must exist under
# C:\Oracle\client19_64\oracore\zoneinfo on THIS machine.
# v$timezone_file on the DB server is not enough by itself.
# ORA_TZFILE=timezlrg_1.dat
