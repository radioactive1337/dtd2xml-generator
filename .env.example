# LLM (OpenAI-compatible API)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your-token-here
LLM_MODEL=gpt-4o-mini

# Application
APP_HOST=0.0.0.0
APP_PORT=8080

# Oracle Client (required for Oracle Database 11.2 and earlier)
# ORACLE_CLIENT_LIB_DIR: folder with oci.dll (often ...\client_1\bin)
# ORACLE_HOME: client home (parent of bin), required for timezone files (ORA-01804)
ORACLE_USE_THICK_MODE=true
ORACLE_CLIENT_LIB_DIR=C:\oracle\product\21.3.0\client_1\bin
ORACLE_HOME=C:\oracle\product\21.3.0\client_1
# If ORA-01804 persists, match DB file from: SELECT * FROM v$timezone_file
# ORA_TZFILE=timezlrg_26.dat
