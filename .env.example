# LLM (OpenAI-compatible API)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=your-token-here
LLM_MODEL=gpt-4o-mini

# Application
APP_HOST=0.0.0.0
APP_PORT=8080

# Oracle Instant Client (required for Oracle Database 11.2 and earlier)
# Download: https://www.oracle.com/database/technologies/instant-client/downloads.html
ORACLE_USE_THICK_MODE=true
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_19_22
